<style>
  :root {
    --bg: #030a03;
    --bg2: #060f06;
    --green: #00ff41;
    --green-dim: #00c832;
    --green-dark: #004d14;
    --green-glow: rgba(0,255,65,0.15);
    --amber: #ffb000;
    --red: #ff3131;
    --cyan: #00e5ff;
    --text: #b0ffb8;
    --text-dim: #5a8c60;
    --border: #1a3d1a;
    --card-bg: rgba(0,15,0,0.85);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Share Tech Mono', monospace;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Scanline overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.08) 2px,
      rgba(0,0,0,0.08) 4px
    );
    pointer-events: none;
    z-index: 999;
  }

  /* Matrix rain canvas */
  #matrix-canvas {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    opacity: 0.04;
    pointer-events: none;
    z-index: 0;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px 60px;
  }

  /* Header */
  header {
    text-align: center;
    padding: 60px 20px 40px;
    position: relative;
  }

  .header-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    letter-spacing: 6px;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 16px;
    animation: fadeIn 1s ease;
  }

  h1 {
    font-family: 'Orbitron', sans-serif;
    font-size: clamp(28px, 5vw, 64px);
    font-weight: 900;
    color: var(--green);
    text-shadow:
      0 0 10px var(--green),
      0 0 30px rgba(0,255,65,0.4),
      0 0 60px rgba(0,255,65,0.2);
    letter-spacing: 4px;
    line-height: 1.1;
    animation: flicker 6s infinite;
  }

  .subtitle {
    margin-top: 14px;
    font-size: 13px;
    color: var(--text-dim);
    letter-spacing: 3px;
  }

  .subtitle span {
    color: var(--amber);
    text-shadow: 0 0 8px var(--amber);
  }

  .divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--green), transparent);
    margin: 30px 0;
    opacity: 0.4;
  }

  /* Stats bar */
  .stats-bar {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
    margin: 20px 0 40px;
    padding: 16px;
    border: 1px solid var(--border);
    background: var(--card-bg);
    border-radius: 4px;
  }

  .stat {
    text-align: center;
  }

  .stat-val {
    font-family: 'Orbitron', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--green);
    text-shadow: 0 0 10px var(--green);
  }

  .stat-label {
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* Filter tabs */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 30px;
    justify-content: center;
  }

  .filter-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    padding: 6px 14px;
    cursor: pointer;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: all 0.2s;
    border-radius: 2px;
  }

  .filter-btn:hover, .filter-btn.active {
    border-color: var(--green);
    color: var(--green);
    background: var(--green-glow);
    text-shadow: 0 0 6px var(--green);
    box-shadow: 0 0 10px rgba(0,255,65,0.1);
  }

  /* Search */
  .search-wrapper {
    position: relative;
    max-width: 500px;
    margin: 0 auto 30px;
  }

  .search-wrapper::before {
    content: '//SEARCH>';
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--green-dim);
    font-size: 11px;
    pointer-events: none;
    z-index: 2;
  }

  #search {
    width: 100%;
    background: var(--card-bg);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: 'Share Tech Mono', monospace;
    font-size: 13px;
    padding: 12px 16px 12px 100px;
    outline: none;
    border-radius: 2px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  #search:focus {
    border-color: var(--green);
    box-shadow: 0 0 15px rgba(0,255,65,0.1);
  }

  #search::placeholder { color: var(--text-dim); }

  /* Grid */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 16px;
  }

  /* Card */
  .card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 18px 20px;
    transition: all 0.25s;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    animation: cardIn 0.4s ease both;
  }

  .card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--green);
    opacity: 0;
    transition: opacity 0.2s;
    box-shadow: 0 0 8px var(--green);
  }

  .card:hover {
    border-color: rgba(0,255,65,0.4);
    background: rgba(0,25,0,0.9);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.5), 0 0 20px rgba(0,255,65,0.05);
  }

  .card:hover::before { opacity: 1; }

  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 10px;
    gap: 10px;
  }

  .card-num {
    font-family: 'Orbitron', sans-serif;
    font-size: 10px;
    font-weight: 700;
    color: var(--text-dim);
    min-width: 28px;
    margin-top: 2px;
  }

  .card-title-wrap { flex: 1; }

  .card-title {
    font-family: 'Orbitron', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: var(--green);
    text-shadow: 0 0 6px rgba(0,255,65,0.3);
    margin-bottom: 3px;
    word-break: break-word;
  }

  .card-url {
    font-size: 10px;
    color: var(--cyan);
    opacity: 0.7;
    word-break: break-all;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .card-url:hover { opacity: 1; text-decoration: underline; }

  .tag {
    font-size: 9px;
    padding: 2px 8px;
    border-radius: 2px;
    letter-spacing: 1px;
    text-transform: uppercase;
    font-weight: bold;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .tag-pentest  { background: rgba(255,49,49,0.15);  color: var(--red);   border: 1px solid rgba(255,49,49,0.3); }
  .tag-learn    { background: rgba(0,229,255,0.1);   color: var(--cyan);  border: 1px solid rgba(0,229,255,0.25); }
  .tag-tools    { background: rgba(255,176,0,0.1);   color: var(--amber); border: 1px solid rgba(255,176,0,0.25); }
  .tag-ctf      { background: rgba(0,255,65,0.1);    color: var(--green); border: 1px solid rgba(0,255,65,0.25); }
  .tag-osint    { background: rgba(180,0,255,0.12);  color: #d580ff;      border: 1px solid rgba(180,0,255,0.3); }
  .tag-malware  { background: rgba(255,49,49,0.08);  color: #ff8080;      border: 1px solid rgba(255,49,49,0.2); }
  .tag-news     { background: rgba(0,229,255,0.08);  color: #80f0ff;      border: 1px solid rgba(0,229,255,0.2); }
  .tag-crypto   { background: rgba(255,200,0,0.1);   color: #ffd040;      border: 1px solid rgba(255,200,0,0.25); }
  .tag-network  { background: rgba(0,255,65,0.08);   color: #80ffb0;      border: 1px solid rgba(0,255,65,0.2); }
  .tag-privacy  { background: rgba(100,100,255,0.1); color: #a0a0ff;      border: 1px solid rgba(100,100,255,0.25); }

  .card-desc {
    font-size: 12px;
    color: var(--text-dim);
    line-height: 1.6;
    margin-top: 8px;
    border-top: 1px solid var(--border);
    padding-top: 8px;
  }

  /* No results */
  .no-results {
    text-align: center;
    padding: 60px 20px;
    color: var(--text-dim);
    display: none;
    grid-column: 1/-1;
  }

  .no-results h3 {
    font-family: 'Orbitron', sans-serif;
    color: var(--red);
    margin-bottom: 8px;
  }

  /* Footer */
  footer {
    text-align: center;
    padding: 30px;
    font-size: 11px;
    color: var(--text-dim);
    border-top: 1px solid var(--border);
    letter-spacing: 2px;
    margin-top: 40px;
  }

  footer span { color: var(--green); }

  /* Animations */
  @keyframes flicker {
    0%,95%,100% { opacity: 1; }
    96% { opacity: 0.85; }
    97% { opacity: 1; }
    98% { opacity: 0.9; }
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes cardIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hidden { display: none !important; }
</style>
</head>
